generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-debian-node-18.x"]
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  price       Float
  category    String?
  brand       String?
  imageUrl    String?
  isActive    Boolean  @default(false)
  isCigarette Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id             Int      @id @default(autoincrement())
  customerName   String?
  totalAmount    Float
  items          String   // En SQLite guardamos un JSON stringificado
  
  createdAt      DateTime @default(now())
}
