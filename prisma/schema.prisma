generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  price       Float
  category    String?
  brand       String?
  imageUrl    String?
  isActive    Boolean  @default(false)
  isPromo     Boolean  @default(false)
  oldPrice    Float?
  isFeatured  Boolean  @default(false)
  isNewArrival Boolean @default(false)
  isCigarette Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CarouselSlide {
  id          Int      @id @default(autoincrement())
  title       String?
  imageUrl    String
  linkUrl     String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id             Int      @id @default(autoincrement())
  customerName   String?
  totalAmount    Float
  items          String   // En SQLite guardamos un JSON stringificado
  
  createdAt      DateTime @default(now())
}
